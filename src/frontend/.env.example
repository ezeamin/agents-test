# ── Cognito (Hosted UI + PKCE) ────────────────────────────────────────────────
# Domain of your Cognito User Pool (no trailing slash)
VITE_COGNITO_DOMAIN=http://localhost:5173

# App client ID (SPA client — no client secret)
VITE_COGNITO_CLIENT_ID=your_client_id_here

# Allowed callback URL registered in the App Client settings
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/debug

# Allowed sign-out URL registered in the App Client settings
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/login

# ── WebRTC ICE Servers ────────────────────────────────────────────────────────
# Comma-separated list of STUN/TURN URLs.
# Defaults to two public Google STUN servers if not set.
# For production, use a TURN server (Twilio, Metered.ca, Cloudflare, etc.)
VITE_ICE_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
