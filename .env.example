# ─── Service Providers ────────────────────────────────────────────
# STT: WHISPER | WHISPER_STREAM (default) | DEEPGRAM
STT_SERVICE_PROVIDER=WHISPER_STREAM
# TTS: CHATTERBOX_SERVER (default) | CHATTERBOX_SERVER_OPENAI | PIPER | POLLY | ELEVENLABS
TTS_SERVICE_PROVIDER=CHATTERBOX_SERVER

# ─── Server Hosts ─────────────────────────────────────────────────
# When running all services with docker compose on a single machine, set
# EC2_HOST=localhost (nova-agent uses host networking and reaches STT/TTS
# containers via the host loopback on their mapped ports 8000 / 8004).
EC2_HOST=localhost
# Override per service (optional, falls back to EC2_HOST)
# EC2_HOST_WHISPER_STREAM=
# EC2_HOST_CHATTERBOX=
# EC2_HOST_PIPER=

# ─── Server Ports (defaults shown) ───────────────────────────────
EC2_WHISPER_PORT=8000
EC2_CHATTERBOX_PORT=8004
EC2_PIPER_PORT=5002

# ─── AWS Credentials (for Bedrock LLM and Polly TTS) ─────────────
# If running in an EC2 instance with IAM role enabled, feel free to comment these out
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# ─── Deepgram (only if STT_SERVICE_PROVIDER=DEEPGRAM) ────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ─── Piper TTS (only if TTS_SERVICE_PROVIDER=PIPER) ──────────────
CURRENT_VOICE=es_AR-daniela-high.onnx
CURRENT_VOICE_CONFIG=es_AR-daniela-high

# ─── HuggingFace (required by STT and TTS Docker containers) ──────
# Token needed to download Whisper and Chatterbox model weights from HF Hub
HF_TOKEN=

# ─── WhisperLiveKit (STT custom container) ────
STT_WHISPER_IMAGE=
# Model size [tiny | base | small | medium (default) | large]
WHISPER_MODEL=medium
# Language code passed to --language (default: es)
WHISPER_LANG=es

# ─── Chatterbox-Server (TTS custom container) ────
TTS_CHATTERBOX_IMAGE=

# ─── Frontend (Cognito + WebRTC) ──────────────────────────────────
# These VITE_* variables are baked into the React bundle at docker build time.
# Changing them requires rebuilding the image (docker compose up --build).

# Cognito Hosted UI — PKCE flow
VITE_COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your_cognito_app_client_id
# Must match the "Allowed callback URL" registered in the App Client
VITE_COGNITO_REDIRECT_URI=https://pipecat-strata.click
# Must match the "Allowed sign-out URL" registered in the App Client
VITE_COGNITO_LOGOUT_URI=https://pipecat-strata.click

# ICE Servers (comma-separated STUN/TURN URLs)
# Defaults to Google STUN if not set. Use a TURN server in production.
VITE_ICE_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
